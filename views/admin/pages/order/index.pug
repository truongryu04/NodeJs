extends ../../layouts/default.pug
include ../../mixins/fillter-status
include ../../mixins/search
include ../../mixins/pagination.pug
include ../../mixins/alert.pug
include ../../mixins/format-date-time.pug

block main

    - const orderFilterStatus = typeof fillterStatus !== "undefined" ? fillterStatus : []
    - const orderKeyword = typeof keyword !== "undefined" ? keyword : ""
    - const orderPagination = typeof pagination !== "undefined" ? pagination : { currentPage: 1, limitItem: orders.length, totalPage: 1 }

    +alert-success("5000")
    +alert-error("5000")
    if(role.permissions.includes("order_view"))
        h1(class="mb-4") Danh sách đơn hàng
        .card.mb-3
            .card-header Bộ lọc và tìm kiếm
            .card-body
                .row
                    .col-6
                        if orderFilterStatus.length > 0
                            +fillter-status(orderFilterStatus)
                    .col-6
                        +search(orderKeyword)
        .card.mb-3
            .card-header Danh sách đơn hàng
            .card-body
                table(class="table table-hover table-sm align-middle")
                    thead
                        tr
                            th STT
                            th Mã đơn
                            th Khách hàng
                            th Số điện thoại
                            th Địa chỉ
                            th Số lượng SP
                            th Tổng tiền
                            th Thanh toán
                            th Trạng thái
                            th Ngày tạo
                            th Hành động
                    tbody
                        if (orders.length > 0)
                            each item, index in orders
                                tr
                                    td #{(orderPagination.currentPage - 1) * orderPagination.limitItem + index + 1}
                                    td #{item._id}
                                    td #{item.userInfor && item.userInfor.fullName ? item.userInfor.fullName : "-"}
                                    td #{item.userInfor && item.userInfor.phone ? item.userInfor.phone : "-"}
                                    td #{item.userInfor && item.userInfor.address ? item.userInfor.address : "-"}
                                    td #{item.totalProducts}
                                    td #{item.totalAmount}$
                                    td #{item.paymentMethodLabel}
                                    td
                                        span(class=`badge ${item.statusBadgeClass}`) #{item.statusLabel}
                                    td
                                        +formatDateTime(item.createdAt)
                                    td
                                        a(
                                            href=`${prefixAdmin}/order/detail/${item._id}`
                                            class="btn btn-secondary btn-sm"
                                        ) Chi tiết
                        else
                            tr
                                td(colspan="11" class="text-center") Chưa có đơn hàng nào
        if orderPagination.totalPage > 1
            +pagination(orderPagination)